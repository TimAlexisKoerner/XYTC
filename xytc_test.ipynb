   "source": [
    "import matplotlib.pyplot as plt\n",
    "from circuit import XYTCCircuit\n",
    "\n",
    "L = 3\n",
    "xytc = XYTCCircuit(L)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 6))\n",
    "xytc.plot(ax=ax)\n",
    "plt.title(f\"XYTC Chess Board Lattice (L={L})\", fontsize=16)\n",
    "plt.show()\n",
    "\n",
    "\n",
    "xytc.draw()"
   ]
  }
